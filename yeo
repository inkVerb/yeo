#!/bin/bash
#inkVerbYeo! verb.ink

# This is the "Yeoman" who manages a Verber by interacting with "Serfs", "Knights", the "Donjon", et cetera.
## This uses "yeo" to execute commands relevant to a Verber, similarly to how "apt", "yum", and "pacman" manage packages.
## yeo streamlines help queries, checks for required parameters, and provides a production-worthy layer of "fool-proofing".
## yeo retrieves available options, tools, settings, notes, parameter requirements, et cetera from the Verber assets themselves using functions & tools like grep and occasionally a central index. This is partially why formatting Serfs is important.
## This is NOT at all affiliated with http://yeoman.io/, which uses "yo".

# How to use:
## yeo surname subname setting1 setting2 setting3 setting4 -o option1 option2 option3 

# Put the path to the setting file here
YEOSET=/var/local/yeo/yeo.set

# Include the setting file
. ${YEOSET}


# Settings, Options, and input variables

## Parse arguments
SURNAME=${1}
SUBNAME=${2}
RUNSERF=${SURNAME}${SUBNAME}
ALLARGS=($@)
SERFSET=$(echo ${ALLARGS} | sed "s/ -.*//") #Get the required settings
SERFOPT=$(echo ${ALLARGS} | sed "s/${SERFSET}//") #Get the options and their flags
ALLSETOPT=(${SERFSET} ${SERFOPT})
ALLSONAME=(${vsetnames[@]} ${voptnames[@]})
### Create an array of the input Settings for easy counting and matching
SERFSETARY=(${SERFSET})

## Get Serf meta
source ${SERFS}/${RUNSERF}

# Validity check functions

## Present (merely checks if a Setting is present in the command)
isPresent() {
local Present=$1
local vvar=$2
if [ -n $Present ]; then
isPresent=true; else
isPresent=false; fi

if [ $isPresent = false ]; then
echo "$vvar must be present."
exit 55; fi
}

## Choice (a set of multiple-choice options)
isChoice() {
local Choice=$1
local vvar=$2
local vchoices=$3
if [ echo $vchoices | grep $Choice ]; then
isChoice=true; else
isChoice=false; fi

if [ $isChoice = false ]; then
echo "$vvar must be one of: $vchoices."
exit 55; fi
}

## NA OR...
isNAopt() {
local NAopt=$1
local vvar=$2
if [ -n $NA ]; then
isNAopt=true; else
isNAopt=false; fi

if [ $isNAopt = false ]; then
echo "$vvar must be present."
exit 55; fi
}

## IP4
### Thanks http://www.linuxjournal.com/content/validating-ip-address-bash-script
isIP4() {
local IP4=$1
local vvar=$2
if [[ $IP4 =~ ^[:digit:]{1,3}\.[:digit:]{1,3}\.[:digit:]{1,3}\.[:digit:]{1,3}$ ]]; then
### Create 4 separate variables
OIFS=$IFS
IFS='.'
ip=($IP4)
IFS=$OIFS
 if [[ ${IP4[0]} -le 255 && ${IP4[1]} -le 255 && ${IP4[2]} -le 255 && ${IP4[3]} -le 255 ]]; then
 isIP4=true; else
 isIP4=false; fi
else
isIP4=false;
fi

if [ $isIP4 = false ]; then
echo "$vvar must be a valid IP4 address."
exit 55; fi
}

## IP6
### Thanks https://stackoverflow.com/questions/31457586/how-can-i-check-ip-version-4-or-6-in-shell-script #Native POSIX (no bashisms) solution without external calls
isIP6() {
local IP6=$1
local vvar=$2
if [ "$IP6" != "${IP6#[:xdigit:]*:}" ] && [ "$IP6" = "${IP6#*[^:xdigit:]}" ] && [ "${IP6#*[:xdigit:][:xdigit:][:xdigit:][:xdigit:][:xdigit:]}" = "${IP6#*:*:*:*:*:*:*:*:*:}" ]; then
isIP6=true; else
isIP6=false; fi

if [ $isIP6 = false ]; then
echo "$vvar must be a valid IP6 address."
exit 55; fi
}

## Integer
isInt() {
local Int=$1
local vvar=$2
if [[ "$Int" =~ [:digit:]+$ ]]; then
isInt=true; else
isInt=false; fi

if [ $isInt = false ]; then
echo "$vvar must be a valid integer."
exit 55; fi
}

## Float
isInt() {
local Int=$1
local vvar=$2
if [[ "$Int" =~ [-+]?[:digit:]+\.?[:digit:]*$ ]]; then
isInt=true; else
isInt=false; fi

if [ $isInt = false ]; then
echo "$vvar must be a valid integer or decimal."
exit 55; fi
}

## HEX
### Thanks https://stackoverflow.com/questions/7662465/bash-is-there-a-simple-way-to-check-whether-a-string-is-a-valid-sha-1-or-md5
isHEX() {
local HEX=$1
local vvar=$2
if [[ "$HEX" =~ [:xdigit:]+$ ]]; then
isHEX=true; else
isHEX=false; fi

if [ $isHEX = false ]; then
echo "$vvar must be hexadecimal."
exit 55; fi
}

## az
isaz() {
local az=$1
local vvar=$2
if [[ "$az" =~ [:lower:]+$ ]]; then
isaz=true; else
isaz=false; fi

if [ $isaz = false ]; then
echo "$vvar must only include lowercase letters."
exit 55; fi
}

## azAZ
isazAZ() {
