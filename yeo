local vvar=$2
if [[ "$azAZ" =~ [:alpha:]+$ ]]; then
isazAZ=true; else
isazAZ=false; fi

if [ $isazAZ = false ]; then
echo "$vvar must only include uppercase and/or lowercase letters."
