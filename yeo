local vvar=$2
if [[ "$azAZ09Punct" =~ [:graph:]+$ ]]; then
isazAZ09Punct=true; else
isazAZ09Punct=false; fi

if [ $isazAZ09Punct = false ]; then
echo "$vvar must only include uppercase letters, lowercase letters, digits, and/or punctuation."
exit 55; fi
}

## FileDir ([azAZ09.-_])
isFileDir() {
local FileDir=$1
local vvar=$2
if [[ "$FileDir" =~ [[:alnum:]\.\-_]+$ ]]; then
isFileDir=true; else
isFileDir=false; fi

if [ $isFileDir = false ]; then
echo "$vvar must be a \"normal\" filename: alphanumeric; CAPS, hyphen, and underscore allowed; but no other special characters or spaces."
exit 55; fi
}

## URL (http{s}://[az09.].az)
isURL() {
local Domain=$1
local vvar=$2
if [[ "$Domain" =~ "http"+[s]?"://"+[[:lower:][:digit:]\.\-_]+\.[:lower:]+$ ]]; then
isDomain=true; else
isDomain=false; fi

if [ $isDomain = false ]; then
echo "$vvar must be a \"normal\" URL: domain, including alphanumeric characters, underscore, and hyphen, subdomains allowed, preceeded by either http:// or https://"
exit 55; fi
}

## Domain (az09.az)
isDomain() {
local Domain=$1
local vvar=$2
if [[ "$Domain" =~ [[:lower:][:digit:]\.\-_]+\.[:lower:]+$ ]]; then
isDomain=true; else
isDomain=false; fi

if [ $isDomain = false ]; then
echo "$vvar must be a \"normal\" domain, including alphanumeric characters, underscore, and hyphen, subdomains allowed if included, ie:  inksaverb.com  sub.inkisaverb.com  etc.sub.inkisaverb.com"
exit 55; fi
}

## verbTLD (valid, accepted TLDs; not full, proper verbURI)
isverbTLD() {
local verbTLD=$1
local vvar=$2
if [ echo ${VERBTLDS[@]} | grep $verbTLD ]; then
isverbTLD=true; else
isverbTLD=false; fi

if [ $isverbTLD = false ]; then
echo "$vvar must a valid verb TLD."
exit 55; fi
}


