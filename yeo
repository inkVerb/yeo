## Usage message
usageMessage()
{
echo "
Help:  ${SURNAME} ${SUBNAME} --h or --help  (to see this information)

${usagenotes}

Usage: ${SURNAME} ${SUBNAME} ${vsetslugs[@]} [Optional settings, se below ]
Options:"
local k=0
while [ $k != ${#voptflags[@]} ]; do
echo " -${voptflags[$k]}  ${voptnames[$k]}"
k=`expr ${k} + 1`
done
### Display any multiple choice options
if [ echo ${vopttypes[$k]} | grep "Choice" ]; then
#### Create an Options array and assign the Flags as keys to the Option Type values of the array
##### Later we recall the value of $type_element as: ${!optsTypeFAK[$optFlagKey]}
 local k=0
 declare -A optsTypeFAK
 while [ $k != ${#voptflags[@]} ]; do
 optsTypeFAK[${voptflags[$k]}]=${vopttypes[$k]}
 k=`expr ${k} + 1`
 done
#### List each Choice description
 for flg in "${!optsTypeFAK[@]}"; do
   if [[ "${optsTypeFAK[$flg]}" = "Choice" ]]; then
    local flagChoices="voptFC_$flg"
    echo " -$flg  Choose: ${!flagChoices}"
   fi
 done
fi
}

## Validate the Settings of the Serf
getSetValidation() {

### Check that all settings are present
if [ ${#SERFSETARY[@]} = ${#vsetnames[@]} ]; then
setCount=true; else
setCount=false
echo "Include all settings:"
#### Put each element on its own line
printf '%s\n' "${vsetnames[@]}"
exit 55; fi

### Validate each setting and option
local k=0
for SETINPUT in ${SERFSETARY[@]}; do
#### Prepare any multiple choice Settings
##### Two-stage empty set to avoid errors when not a Choice Type
 local showOptChoices=NULLCHOICES
 local NULLCHOICES=
 if [ "${vsettypes[$k]}" = "Choice" ]; then
  showSetChoices="vsetMC_$k"
 fi
#### Run the check
is${vsettypes[$k]} $SETINPUT "${vsetnames[$k]}" "${!showSetChoices}"
k=`expr ${k} + 1`
done

### Declare results
${RUNSERF}SetVal=true
return 0
}

## Validate the Options of the Serf
getOptValidation() {

### Create an Options array and assign the Flags as keys to the Option Type values of the array
#### Later we recall the value of $type_element as: ${!optsTypeFAK[$optFlagKey]}
local k=0
declare -A optsTypeFAK
while [ $k != ${#voptflags[@]} ]; do
optsTypeFAK[${voptflags[$k]}]=${vopttypes[$k]}
k=`expr ${k} + 1`
done

### Create an Options array and assign the Flags as keys to the Option Slug values of the array
#### Later we recall the value of $slug_element as: ${!optsSlugFAK[$optFlagKey]}
local k=0
declare -A optsSlugFAK
while [ $k != ${#voptflags[@]} ]; do
optsSlugFAK[${voptflags[$k]}]=${voptslugs[$k]}
k=`expr ${k} + 1`
done

### Create an Options Name array and assign the Flags as keys to the Option Name values of the array
#### Later we recall the value of $name_element as: ${!optsSlugFAK[$optFlagKey]}
local k=0
declare -A optsNameFAK
while [ $k != ${#voptflags[@]} ]; do
optsNameFAK[${voptflags[$k]}]="${voptnames[$k]}"
k=`expr ${k} + 1`
done

### Declare the Option Input variables as NULLIN now so setting Options requires positive attendance
for optFlagKey in ${voptflags[@]}; do
#### We set the value of the Type as NULLIN, ie $Int=NULLIN, $Domain=NULLIN, thanks https://unix.stackexchange.com/questions/23111/what-is-the-eval-command-in-bash
local eval ${optsSlugFAK[$optFlagKey]}=NULLIN
done

### Create a getops list
local optGetopts=
for optF in ${voptflags[@]}; do
optGetopts="${optGetopts}${optF}:"
done

### Check the Flags with getopts
#### Begin the options with a colon for silent error reporting
while getopts :h${optGetopts} vOptInput; do
case $vOptInput in
#### Help option
# h)
#  usageMessage
#  exit 0
#  ;;
#### Each Flag and Opiton in turn
 for optFlagKey in ${voptflags[@]}; do
 ${optFlagKey})
##### Set the argument to match the value of $slug_element
  local eval ${optsSlugFAK[$optFlagKey]}=$OPTARG
##### Prepare any multiple choice Options
###### Two-stage empty set to avoid errors when not a Choice Type
  local showOptChoices=NULLCHOICES
  local NULLCHOICES=
  if [[ "${optsTypeFAK[$optFlagKey]}" = "Choice" ]]; then
   showOptChoices="voptFC_$optFlagKey"
  fi
##### Run the validation function on that Type or if empty say so
  is${optsTypeFAK[$optFlagKey]} ${!optsSlugFAK[$optFlagKey]} "${optsNameFAK[$optFlagKey]}" "${!showOptChoices}"
  ;;
 done
esac
done
####DEV: http://wiki.bash-hackers.org/howto/getopts_tutorial
####     https://rsalveti.wordpress.com/2007/04/03/bash-parsing-arguments-with-getopts/
####     https://jonalmeida.com/posts/2013/05/26/different-ways-to-implement-flags-in-bash/
####     https://stackoverflow.com/questions/7069682/how-to-get-arguments-with-flags-in-bash-script

### Put options in correct order
for optFlagKey in ${voptflags[@]}; do
ORDEREDOPT="${ORDEREDOPT} ${!optsFAK[$optFlagKey]}"
done

#done ##DEV: remove if it works, this may be an orphan

### Declare results
${RUNSERF}OptVal=true
return 0
}


