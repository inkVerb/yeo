}

## AZ09
isAZ09() {
local AZ09=$1
local vvar=$2
if [[ "$AZ09" =~ [[:upper:][:digit:]]+$ ]]; then
isAZ09=true; else
isAZ09=false; fi

if [ $isAZ09 = false ]; then
echo "$vvar must only include lowercase letters and/or digits."
exit 55; fi
}

## azAZ09
isazAZ09() {
local azAZ09=$1
local vvar=$2
if [[ "$azAZ09" =~ [:alnum:]+$ ]]; then
isazAZ09=true; else
isazAZ09=false; fi

if [ $isazAZ09 = false ]; then
echo "$vvar must only include uppercase letters, lowercase letters, and/or digits."
